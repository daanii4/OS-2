# Copy to `.env` and fill in values. Never commit `.env`.

# ─── DATABASE ───────────────────────────────────────────────────────────────
# Use direct db host :5432 for local dev; pooler only for DATABASE_URL in prod if desired.
# DIRECT_URL must never use the Supabase pooler hostname.
DATABASE_URL=
DIRECT_URL=

# ─── SUPABASE AUTH ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── APP URL (optional) ─────────────────────────────────────────────────────
# Does NOT affect whether the site loads — only invite redirect URLs and link hrefs in emails.
# On Vercel, VERCEL_URL is used if these are unset (preview URLs work; custom domain: set one below).
# Resend only needs RESEND_API_KEY + RESEND_FROM; public URL is for links inside messages, not API auth.
NEXT_PUBLIC_APP_URL=
APP_URL=

# ─── RESEND (transactional email) ─────────────────────────────────────────────
# API key from https://resend.com/api-keys — server only, never NEXT_PUBLIC_
RESEND_API_KEY=
# "From" is not stored in the Resend UI; the app reads RESEND_FROM. Use Friendly Name plus a
# mailbox at the same domain you verified in Resend (Domains page must show Verified).
RESEND_FROM=

# DKIM / SPF / MX for sending are configured at your DNS provider using the records
# Resend shows for your domain. Do not put DNS record values in this file.

# ─── OPTIONAL ─────────────────────────────────────────────────────────────────
DEFAULT_TENANT_SLUG=
BLOB_READ_WRITE_TOKEN=

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  owner
  assistant
  counselor
}

enum TenantPlan {
  starter
  growth
  enterprise
}

enum StudentStatus {
  active
  graduated
  transferred
  inactive
}

enum SessionFormat {
  individual
  group
}

enum Grade {
  K
  G1
  G2
  G3
  G4
  G5
  G6
  G7
  G8
  G9
  G10
  G11
  G12
}

enum SessionType {
  intake_assessment
  behavioral_observation
  classroom_support
  emotional_regulation
  group_behavior_support
  peer_conflict_mediation
  check_in
  crisis
}

enum ReferralStatus {
  open
  in_progress
  completed
  closed
}

enum ConsentStatus {
  active
  expired
  revoked
}

enum AttendanceStatus {
  attended
  no_show
  rescheduled
  cancelled
}

enum IncidentType {
  office_referral
  suspension_iss
  suspension_oss
  teacher_referral
  behavioral_incident
  other
}

enum Severity {
  low
  medium
  high
}

enum PlanStatus {
  active
  completed
  paused
  archived
}

enum SessionFrequency {
  daily
  weekly
  biweekly
  as_needed
}

enum AITrigger {
  new_session
  new_incident
  plan_creation
  milestone_missed
  counselor_request
  regression_alert
}

enum CounselorAction {
  reviewed
  followed
  modified
  ignored
  pending
}

enum MeetingStatus {
  scheduled
  completed
  cancelled
  rescheduled
}

// ─────────────────────────────────────────────
// PROFILES
// Extends Supabase auth.users — id matches auth.users.id exactly
// ─────────────────────────────────────────────

model Tenant {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  subdomain   String     @unique
  owner_email String
  plan        TenantPlan @default(starter)
  active      Boolean    @default(true)
  created_at  DateTime   @default(now())

  profiles        Profile[]
  students        Student[]
  referrals       Referral[]
  consent_records ConsentRecord[]
  incidents       BehavioralIncident[]
  sessions        Session[]
  success_plans       SuccessPlan[]
  ai_analyses         AiAnalysis[]
  meetings            Meeting[]
  student_status_logs StudentStatusLog[]

  @@map("tenants")
}

model Profile {
  id         String   @id // UUID from Supabase Auth — do not generate here
  tenant_id  String?
  name       String
  email      String   @unique
  role       UserRole @default(counselor)
  active     Boolean  @default(true)
  created_at DateTime @default(now())

  // Relations
  tenant               Tenant?               @relation(fields: [tenant_id], references: [id])
  assigned_students    Student[]            @relation("AssignedCounselor")
  sessions             Session[]
  logged_incidents     BehavioralIncident[]
  created_plans        SuccessPlan[]
  ai_analyses_reviewed AiAnalysis[]
  assigned_referrals   Referral[]            @relation("AssignedReferrals")
  created_referrals    Referral[]            @relation("CreatedReferrals")
  consent_records      ConsentRecord[]
  counselor_meetings   Meeting[]             @relation("CounselorMeetings")
  created_meetings     Meeting[]             @relation("CreatedMeetings")
  student_status_logs  StudentStatusLog[]    @relation("StudentStatusChanges")

  @@index([tenant_id])
  @@map("profiles")
}

// ─────────────────────────────────────────────
// STUDENTS
// ─────────────────────────────────────────────

model Student {
  id                      String        @id @default(uuid())
  tenant_id               String?
  first_name              String
  last_name               String
  grade                   Grade
  school                  String
  district                String
  assigned_counselor_id   String?
  referral_source         String
  presenting_problem      String        @db.Text // SENSITIVE — never in list endpoints
  intake_date             DateTime
  status                  StudentStatus @default(active)
  session_format          SessionFormat @default(individual)
  baseline_incident_count Int?
  baseline_window_start   DateTime?
  baseline_window_end     DateTime?
  school_year             String?
  general_notes           String?       @db.Text // NOT AI-analyzed per spec
  escalation_active       Boolean       @default(false)
  intake_files            Json? // Array of { name, url, uploaded_at, referred_by?, brief_description?, referral_date? } — Vercel Blob; optional at intake; doc/PDF only
  created_at              DateTime      @default(now())
  updated_at              DateTime      @updatedAt

  // Relations
  tenant             Tenant?               @relation(fields: [tenant_id], references: [id])
  assigned_counselor Profile?             @relation("AssignedCounselor", fields: [assigned_counselor_id], references: [id])
  incidents          BehavioralIncident[]
  sessions           Session[]
  success_plans      SuccessPlan[]
  ai_analyses        AiAnalysis[]
  referrals          Referral[]
  consent_records    ConsentRecord[]
  meetings           Meeting[]
  status_logs        StudentStatusLog[]

  @@index([tenant_id])
  @@index([tenant_id, assigned_counselor_id])
  @@map("students")
}

// ─────────────────────────────────────────────
// BEHAVIORAL INCIDENTS
// Primary progress measurement unit
// ─────────────────────────────────────────────

model BehavioralIncident {
  id                String       @id @default(uuid())
  tenant_id         String?
  student_id        String
  incident_date     DateTime
  incident_type     IncidentType
  suspension_days   Float?       // Only for suspension types. 0.5 = half day.
  severity          Severity
  description       String       @db.Text
  reported_by       String       // Teacher name, admin, or other — original reporter
  logged_by         String       // FK → profiles — who entered it into the system
  linked_session_id String?      // Optional — if discussed in a session
  created_at        DateTime     @default(now())

  // Relations
  tenant            Tenant?  @relation(fields: [tenant_id], references: [id])
  student           Student  @relation(fields: [student_id], references: [id])
  logged_by_profile Profile  @relation(fields: [logged_by], references: [id])
  linked_session    Session? @relation(fields: [linked_session_id], references: [id])

  @@index([tenant_id])
  @@index([tenant_id, student_id])
  @@map("behavioral_incidents")
}

// ─────────────────────────────────────────────
// SESSIONS
// Primary AI input — session_summary is the richest data in the system
// ─────────────────────────────────────────────

model Session {
  id                   String           @id @default(uuid())
  tenant_id            String?
  student_id           String
  counselor_id         String           // Always set from auth — never from request body
  session_date         DateTime
  session_type         SessionType      @default(check_in)
  session_format       SessionFormat    @default(individual)
  duration_minutes     Int              @default(30)
  attendance_status    AttendanceStatus
  session_summary      String?          @db.Text // SENSITIVE — PRIMARY AI INPUT. Never in list endpoints.
  session_goals        Json?            // [{ goal: string, met: boolean }]
  goals_attempted      Int?             // COMPUTED server-side — never written from client
  goals_met            Int?             // COMPUTED server-side — never written from client
  goal_completion_rate Float?           // COMPUTED server-side — (goals_met / goals_attempted) * 100
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt

  // Relations
  tenant           Tenant?               @relation(fields: [tenant_id], references: [id])
  student          Student              @relation(fields: [student_id], references: [id])
  counselor        Profile              @relation(fields: [counselor_id], references: [id])
  linked_incidents BehavioralIncident[]
  ai_analyses      AiAnalysis[]

  @@index([tenant_id])
  @@index([tenant_id, student_id])
  @@map("sessions")
}

// ─────────────────────────────────────────────
// SUCCESS PLANS
// ─────────────────────────────────────────────

model SuccessPlan {
  id                   String           @id @default(uuid())
  tenant_id            String?
  student_id           String
  created_by           String           // FK → profiles — always set from auth
  status               PlanStatus       @default(active)
  goal_statement       String           @db.Text
  target_reduction_pct Float            // Target % reduction from baseline. e.g. 75 = 75% reduction.
  plan_duration_weeks  Int
  focus_behaviors      String[]         // e.g. ['reduce office referrals', 'improve classroom staying']
  session_frequency    SessionFrequency
  milestones           Json?            // Array of milestone objects — see spec section 4.6
  ai_counselor_guide   String?          @db.Text // AI-generated. Updated after each session.
  plan_notes           String?          @db.Text
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt

  // Relations
  tenant             Tenant?  @relation(fields: [tenant_id], references: [id])
  student            Student @relation(fields: [student_id], references: [id])
  created_by_profile Profile @relation(fields: [created_by], references: [id])

  @@index([tenant_id])
  @@index([tenant_id, student_id])
  @@map("success_plans")
}

model Referral {
  id                 String         @id @default(uuid())
  tenant_id          String
  student_id         String
  referral_date      DateTime
  referred_by        String
  brief_description  String?        @db.Text
  intervention_types SessionType[]
  status             ReferralStatus @default(open)
  assigned_to        String?
  linked_consent_id  String?
  created_by         String
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt

  tenant             Tenant         @relation(fields: [tenant_id], references: [id])
  student            Student        @relation(fields: [student_id], references: [id])
  assigned_profile   Profile?       @relation("AssignedReferrals", fields: [assigned_to], references: [id])
  created_by_profile Profile        @relation("CreatedReferrals", fields: [created_by], references: [id])
  consent_record     ConsentRecord? @relation(fields: [linked_consent_id], references: [id])

  @@index([tenant_id])
  @@index([tenant_id, student_id])
  @@map("referrals")
}

model ConsentRecord {
  id                   String        @id @default(uuid())
  tenant_id            String
  student_id           String
  school_year          String
  parent_guardian_name String
  consent_date         DateTime
  district             String
  school               String
  behaviorist_name     String
  status               ConsentStatus @default(active)
  signed_copy_url      String?
  created_by           String
  created_at           DateTime      @default(now())

  tenant             Tenant    @relation(fields: [tenant_id], references: [id])
  student            Student   @relation(fields: [student_id], references: [id])
  created_by_profile Profile   @relation(fields: [created_by], references: [id])
  referrals          Referral[]

  @@index([tenant_id])
  @@index([tenant_id, student_id])
  @@map("consent_records")
}

// ─────────────────────────────────────────────
// AI ANALYSES
// ─────────────────────────────────────────────

model AiAnalysis {
  id                        String          @id @default(uuid())
  tenant_id                 String?
  student_id                String
  triggered_by              AITrigger
  problem_analysis          String          @db.Text
  next_session_guide        String          @db.Text
  recommended_interventions Json            // [{ intervention, rationale, source: { name, url } }]
  escalation_flag           Boolean         @default(false)
  escalation_reason         String?         @db.Text
  counselor_action          CounselorAction @default(pending)
  counselor_notes           String?         @db.Text
  reviewed_by               String?         // FK → profiles
  linked_session_id         String?
  created_at                DateTime        @default(now())

  // Relations
  tenant                Tenant?  @relation(fields: [tenant_id], references: [id])
  student               Student  @relation(fields: [student_id], references: [id])
  reviewed_by_profile   Profile? @relation(fields: [reviewed_by], references: [id])
  linked_session        Session? @relation(fields: [linked_session_id], references: [id])

  @@index([tenant_id])
  @@index([tenant_id, student_id])
  @@map("ai_analyses")
}

// ─────────────────────────────────────────────
// MEETINGS — scheduled counseling / site blocks
// ─────────────────────────────────────────────

model Meeting {
  id               String         @id @default(uuid())
  tenant_id        String
  student_id       String?
  counselor_id     String
  title            String
  meeting_date     DateTime
  duration_minutes Int            @default(30)
  location         String?
  meeting_type     String // student_session | site_block | check_in | group
  status           MeetingStatus  @default(scheduled)
  notes            String?        @db.Text
  created_by       String
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt

  tenant             Tenant   @relation(fields: [tenant_id], references: [id])
  student            Student? @relation(fields: [student_id], references: [id])
  counselor          Profile  @relation("CounselorMeetings", fields: [counselor_id], references: [id])
  created_by_profile Profile  @relation("CreatedMeetings", fields: [created_by], references: [id])

  @@index([tenant_id])
  @@index([tenant_id, counselor_id])
  @@index([tenant_id, meeting_date])
  @@map("meetings")
}

// ─────────────────────────────────────────────
// STUDENT STATUS AUDIT LOG
// ─────────────────────────────────────────────

model StudentStatusLog {
  id          String        @id @default(uuid())
  tenant_id   String
  student_id  String
  changed_by  String
  old_status  StudentStatus
  new_status  StudentStatus
  note        String?       @db.Text
  created_at  DateTime      @default(now())

  tenant             Tenant   @relation(fields: [tenant_id], references: [id])
  student            Student  @relation(fields: [student_id], references: [id])
  changed_by_profile Profile  @relation("StudentStatusChanges", fields: [changed_by], references: [id])

  @@index([tenant_id, student_id])
  @@map("student_status_logs")
}

## Permissions — Enforced at the DB Query Layer

### canAccessStudent() — Required for Every Student-Scoped Route

```typescript
// lib/permissions.ts
export async function canAccessStudent(
  userId: string,
  role: UserRole,
  studentId: string
): Promise<boolean> {
  // Owner and assistant see all students
  if (role === 'owner' || role === 'assistant') return true

  // Counselor: query DB to verify assignment — never trust client-supplied data
  const assignment = await prisma.student.findFirst({
    where: { id: studentId, assigned_counselor_id: userId },
    select: { id: true }
  })
  return !!assignment
}
```

### withRoleGuard() — For Owner/Assistant-Only Routes

```typescript
// lib/permissions.ts — pattern: getUser() + prisma.profile, then check role
import { createClient } from '@/lib/supabase/server'
import { prisma } from '@/lib/prisma'

export function withRoleGuard(
  handler: (req: NextRequest, ctx: RouteContext) => Promise<NextResponse>,
  allowedRoles: UserRole[]
) {
  return async (req: NextRequest, ctx: RouteContext) => {
    const supabase = await createClient()
    const { data: { user }, error } = await supabase.auth.getUser()
    if (error || !user) {
      return NextResponse.json({ error: 'Unauthorized', code: 'UNAUTHORIZED' }, { status: 401 })
    }
    const profile = await prisma.profile.findUnique({
      where: { id: user.id },
      select: { id: true, role: true, active: true },
    })
    if (!profile || !profile.active) {
      return NextResponse.json({ error: 'Forbidden', code: 'FORBIDDEN' }, { status: 403 })
    }
    if (!allowedRoles.includes(profile.role)) {
      return NextResponse.json({ error: 'Forbidden', code: 'FORBIDDEN' }, { status: 403 })
    }
    return handler(req, ctx)
  }
}
```

### DB-Layer Filtering — Never JS-Layer Filtering

```typescript
// CORRECT — filter at DB query level
const students = await prisma.student.findMany({
  where: {
    ...(role === 'counselor' ? { assigned_counselor_id: userId } : {})
  },
  select: {
    id: true,
    first_name: true,
    last_name: true,
    grade: true,
    school: true,
    status: true,
    // session_summary is NEVER included in list queries
    // presenting_problem is NEVER included in list queries
  }
})

// WRONG — never do this
const allStudents = await prisma.student.findMany()
const filtered = allStudents.filter(s => s.assigned_counselor_id === userId)
// ^ Fetches every student from DB before filtering. One middleware bug exposes all records.
```


# Operation Scholars OS — API Route Rules

Every API route in this system handles FERPA-protected student records.
The patterns below are non-negotiable. No route ships without following this structure.

---

## Standard Route Structure — Every Route Follows This Pattern

```typescript
// app/api/[resource]/route.ts
import { NextRequest, NextResponse } from 'next/server'
import { createClient } from '@/lib/supabase/server'
import { prisma } from '@/lib/prisma'
import { canAccessStudent } from '@/lib/permissions'
import { z } from 'zod'

// Define ALL accepted fields explicitly.
// Fields not in this schema are stripped — never reach the DB.
const RequestSchema = z.object({
  // ... fields
})

export async function POST(req: NextRequest) {
  // STEP 1: Authenticate — must be first, always (see Session Retrieval in Route Handlers)
  const supabase = await createClient()
  const { data: { user }, error: authError } = await supabase.auth.getUser()
  if (authError || !user) {
    return NextResponse.json(
      { error: 'Unauthorized', code: 'UNAUTHORIZED' },
      { status: 401 }
    )
  }
  const profile = await prisma.profile.findUnique({
    where: { id: user.id },
    select: { id: true, role: true, active: true, name: true },
  })
  if (!profile || !profile.active) {
    return NextResponse.json(
      { error: 'Forbidden', code: 'FORBIDDEN' },
      { status: 403 }
    )
  }
  const { id: userId, role } = profile

  // STEP 2: Authorize — role check + resource access
  // For student-scoped routes: use canAccessStudent()
  // For role-only checks: use role from profile
  const authorized = await canAccessStudent(userId, role, studentId)
  if (!authorized) {
    return NextResponse.json(
      { error: 'Forbidden', code: 'FORBIDDEN' },
      { status: 403 }
    )
  }

  // STEP 3: Parse + validate — before ANY database operation
  const body = await req.json()
  const parsed = RequestSchema.safeParse(body)
  if (!parsed.success) {
    return NextResponse.json(
      { error: 'Invalid input', code: 'VALIDATION_ERROR', detail: parsed.error.flatten() },
      { status: 400 }
    )
  }

  // STEP 4: Compute server-side fields — never trust client-supplied computed values
  // goals_attempted, goals_met, goal_completion_rate, incident aggregations — always here
  const computedFields = computeFields(parsed.data)

  // STEP 5: Database operation — wrapped in try/catch, always
  try {
    const record = await prisma.resource.create({
      data: {
        ...parsed.data,
        ...computedFields,
        createdById: userId  // always from authenticated profile, never from request body
      }
    })
    return NextResponse.json({ data: record }, { status: 201 })
  } catch (error) {
    // Detailed error → server logs only. Generic message → client.
    console.error('[resource/POST]', error)
    return NextResponse.json(
      { error: 'Server error', code: 'SERVER_ERROR' },
      { status: 500 }
    )
  }
}
```

---

## Error Response Contract

All error responses follow this shape. No exceptions.

```typescript
type ErrorResponse = {
  error: string         // Human-readable. Generic to client — never leaks internals.
  code: ErrorCode       // Machine-readable. Use for client-side handling.
  detail?: unknown      // Validation errors only (zod .flatten() output). Never stack traces.
}

type ErrorCode =
  | 'UNAUTHORIZED'      // No valid session
  | 'FORBIDDEN'         // Session exists but role/access denied
  | 'NOT_FOUND'         // Resource doesn't exist (or counselor not authorized — treat same)
  | 'VALIDATION_ERROR'  // Zod parse failure
  | 'SERVER_ERROR'      // Unexpected error — generic to client, detailed to server log
```


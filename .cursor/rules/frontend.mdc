### 7.2 Standard Chart Component Wrapper

```tsx
// All Recharts components follow this pattern.
// Data is received as a prop — computed server-side, never client-side.
// No API calls, no business logic, no useMemo computations inside chart components.

import {
  ResponsiveContainer, LineChart, Line,
  BarChart, Bar, XAxis, YAxis, CartesianGrid,
  Tooltip, Legend, ReferenceLine,
} from 'recharts'

// Custom tooltip — always use this instead of Recharts default
const ScholarsTooltip = ({ active, payload, label }: TooltipProps<ValueType, NameType>) => {
  if (!active || !payload?.length) return null
  return (
    <div className="bg-olive-900 border border-olive-700 rounded-md shadow-elevated px-3 py-2">
      <p className="font-mono text-data-sm text-white mb-1">{label}</p>
      {payload.map((entry) => (
        <div key={entry.dataKey} className="flex items-center gap-2">
          <span className="w-2 h-2 rounded-full" style={{ backgroundColor: entry.color }} />
          <span className="font-sans text-caption text-olive-300">{entry.name}:</span>
          <span className="font-mono text-data-sm text-white">{entry.value}</span>
        </div>
      ))}
    </div>
  )
}

// X and Y axis style — reuse across all charts
const axisStyle = {
  fontSize: 11,
  fontFamily: 'IBM Plex Mono, monospace',
  fill: '#6E8A4C',  // olive-500
}
```


## next.config.ts

```typescript
// next.config.ts
import type { NextConfig } from 'next'

const nextConfig: NextConfig = {
  // Enforce type and lint checks on build
  typescript: {
    ignoreBuildErrors: false,  // Never set to true — catches type regressions
  },
  eslint: {
    ignoreDuringBuilds: false,
  },
  // Log levels — never log query content in production
  // No serverRuntimeConfig or publicRuntimeConfig needed
}

export default nextConfig
```

